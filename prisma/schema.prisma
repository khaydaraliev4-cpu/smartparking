generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ParkingType {
  CAR
  TRUCK
}

enum PaymentStatus {
  PAID
  FAILED
  PENDING
}

model User {
  id                 String            @id @default(cuid())
  firstName          String
  lastName           String
  email              String            @unique
  licensePlate       String
  passwordHash       String
  geolocationConsent Boolean
  verifiedAt         DateTime?
  createdAt          DateTime          @default(now())
  reservations       Reservation[]
  subscriptions      Subscription[]
  settings           UserSetting?
  parkingLocations   ParkingLocation[] @relation("ReservedBy")
  emailVerifications EmailVerification[]
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  code      String
  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id])
}

model ParkingLocation {
  id               String        @id @default(cuid())
  type             ParkingType
  name             String
  country          String
  region           String
  city             String
  imageUrl         String
  availableFloor   String
  availableRow     String
  availableSpot    String
  lat              Float
  lng              Float
  reservedByUserId String?
  reservedBy       User?         @relation("ReservedBy", fields: [reservedByUserId], references: [id])
  reservations     Reservation[]
}

model Reservation {
  id                String          @id @default(cuid())
  userId            String
  parkingLocationId String
  createdAt         DateTime        @default(now())
  releasedAt        DateTime?
  user              User            @relation(fields: [userId], references: [id])
  parkingLocation   ParkingLocation @relation(fields: [parkingLocationId], references: [id])

  @@index([parkingLocationId, releasedAt])
}

model Subscription {
  id          String        @id @default(cuid())
  userId      String
  plan        String
  amount      Int
  provider    String
  status      PaymentStatus
  activeUntil DateTime
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  message   String
  createdAt DateTime @default(now())
}

model ChatLog {
  id        String   @id @default(cuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String   @unique
  language  String   @default("en")
  theme     String   @default("light")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}
